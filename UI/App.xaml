<Application x:Class="UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:UI.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <helpers:EntryScoringConverter x:Key="EntryScoringConverter" />

            <SolidColorBrush x:Key="DataGridSelectedRowBackgroundBrush" Color="#FFE3F2FD" />
            <SolidColorBrush x:Key="ResultPlaceGoldBrush" Color="#FFFFF0B2" />
            <SolidColorBrush x:Key="ResultPlaceSilverBrush" Color="#FFE8E8E8" />
            <SolidColorBrush x:Key="ResultPlaceBronzeBrush" Color="#FFFFE4C4" />

            <!-- Entry with Scoring=false: gray idle/hover; selected uses light blue. -->
            <Style x:Key="DataGridRowLightBlueWhenSelectedStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Converter={StaticResource EntryScoringConverter}}"
                                       Value="False" />
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                       Value="False" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                       Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="LightGray" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Converter={StaticResource EntryScoringConverter}}"
                                       Value="False" />
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                       Value="False" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                                       Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#FFC8C8C8" />
                    </MultiDataTrigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource DataGridSelectedRowBackgroundBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Results tables: 1st–3rd place rows in gold, silver, bronze when not selected. -->
            <Style x:Key="DataGridRowResultsPlaceStyle"
                   TargetType="DataGridRow"
                   BasedOn="{StaticResource DataGridRowLightBlueWhenSelectedStyle}">
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Place}" Value="1" />
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                       Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource ResultPlaceGoldBrush}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Place}" Value="2" />
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                       Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource ResultPlaceSilverBrush}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Place}" Value="3" />
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                       Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource ResultPlaceBronzeBrush}" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>