<UserControl x:Class="UI.Views.Generic.GenericTableDefaultToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="550">
    <StackPanel Orientation="Horizontal">
        <Button Content="{ui:SymbolIcon Add24}"
                Command="{Binding CreateItemCommand}"
                ToolTip="Создать"
                Margin="5"
                Padding="9" />
        <Button Content="{ui:SymbolIcon Edit24}"
                Command="{Binding EditItemCommand}"
                ToolTip="Редактировать"
                Margin="5"
                Padding="9" />
        <Button Content="{ui:SymbolIcon Delete24}"
                Command="{Binding DeleteItemCommand}"
                ToolTip="Удалить"
                Margin="5"
                Padding="9" />
        <Button Content="{ui:SymbolIcon ArrowClockwise24}"
                Command="{Binding LoadDataCommand}"
                ToolTip="Обновить"
                Margin="5"
                Padding="9" />
        <ui:TextBox
            Icon="{ui:SymbolIcon Search24}"
            Margin="5"
            MinWidth="300"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
</UserControl>