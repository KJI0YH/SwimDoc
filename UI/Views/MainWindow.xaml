<ui:FluentWindow x:Class="UI.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:UI"
                 xmlns:vm="clr-namespace:UI.ViewModels"
                 xmlns:views="clr-namespace:UI.Views"
                 xmlns:table="clr-namespace:UI.ViewModels.Table"
                 xmlns:table1="clr-namespace:UI.Views.Table"
                 xmlns:pages="clr-namespace:UI.Views.Pages"
                 mc:Ignorable="d"
                 Title="SwimDoc"
                 MinWidth="1100"
                 MinHeight="500"
                 WindowState="Maximized"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True">
    <Window.InputBindings>
        <KeyBinding Key="N"
                    Modifiers="Control"
                    Command="{Binding CompetitionSelectionViewModel.CreateNewCommand}" />
        <KeyBinding Key="O"
                    Modifiers="Control"
                    Command="{Binding CompetitionSelectionViewModel.OpenExistingCommand}" />
    </Window.InputBindings>
    <ui:FluentWindow.Resources>
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="47" />
            <Setter Property="Height" Value="47" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="RestoreWindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseWindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ui:NavigationViewItem">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate DataType="{x:Type vm:CompetitionSelectionViewModel}">
            <views:CompetitionSelectionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:EventsViewModel}">
            <table1:EventsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:HeatsViewModel}">
            <table1:HeatsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:EntriesViewModel}">
            <table1:EntriesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:AthletesViewModel}">
            <table1:AthletesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:ClubsViewModel}">
            <table1:ClubsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:AgeGroupsViewModel}">
            <table1:AgeGroupsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type table:SwimStylesViewModel}">
            <table1:SwimStylesView />
        </DataTemplate>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Menu VerticalAlignment="Center">
                <MenuItem Header="Соревнование">
                    <MenuItem Header="Создать"
                              InputGestureText="Ctrl+N"
                              Command="{Binding CompetitionSelectionViewModel.CreateNewCommand}" />
                    <MenuItem Header="Открыть"
                              InputGestureText="Ctrl+O"
                              Command="{Binding CompetitionSelectionViewModel.OpenExistingCommand}" />
                </MenuItem>
                <MenuItem Header="Программа" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToEventsCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding EventsViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding EventsViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding EventsViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding EventsViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Заплывы" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToHeatsCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding HeatsViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding HeatsViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding HeatsViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding HeatsViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Заявки" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToEntriesCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding EntriesViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding EntriesViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding EntriesViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding EntriesViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Спортсмены" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToAthletesCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding AthletesViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding AthletesViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding AthletesViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding AthletesViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Команды" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToClubsCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding ClubsViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding ClubsViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding ClubsViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding ClubsViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Возрастные группы" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToAgeGroupsCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding AgeGroupsViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding AgeGroupsViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding AgeGroupsViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding AgeGroupsViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Дистанции" IsEnabled="{Binding IsCompetitionSelected}">
                    <MenuItem Header="Открыть раздел" Command="{Binding NavigateToSwimStylesCommand}" />
                    <Separator />
                    <MenuItem Header="Создать" Command="{Binding SwimStylesViewModel.CreateItemCommand}" />
                    <MenuItem Header="Изменить" Command="{Binding SwimStylesViewModel.EditItemCommand}" />
                    <MenuItem Header="Удалить" Command="{Binding SwimStylesViewModel.DeleteItemCommand}" />
                    <MenuItem Header="Обновить" Command="{Binding SwimStylesViewModel.LoadDataCommand}" />
                </MenuItem>
                <MenuItem Header="Настройки"></MenuItem>
            </Menu>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource RestoreWindowControlButtonStyle}"
                        Click="MinimizeButton_Click"
                        ToolTip="Minimize"
                        Content="{ui:SymbolIcon Subtract24}" />
                <Button x:Name="RestoreButton"
                        Style="{StaticResource RestoreWindowControlButtonStyle}"
                        Click="RestoreButton_Click"
                        ToolTip="Restore"
                        Content="{ui:SymbolIcon SquareMultiple24}" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseWindowControlButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTip="Close"
                        Content="{ui:SymbolIcon Dismiss24}" />
            </StackPanel>
        </Grid>

        <ui:NavigationView Grid.Row="1" x:Name="NavigationView"
                           PaneDisplayMode="Left"
                           OpenPaneLength="200"
                           IsBackButtonVisible="Auto"
                           Loaded="NavigationView_OnLoaded">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Программа"
                                       Tag="Events"
                                       Icon="{ui:SymbolIcon CalendarLtr24}"
                                       TargetPageType="{x:Type pages:EventsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Заплывы"
                                       Tag="Heats"
                                       Icon="{ui:SymbolIcon SwimmingPool24}"
                                       TargetPageType="{x:Type pages:HeatsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Заявки"
                                       Tag="Entries"
                                       Icon="{ui:SymbolIcon DocumentCopy24}"
                                       TargetPageType="{x:Type pages:EntriesPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Спортсмены"
                                       Tag="Athletes"
                                       Icon="{ui:SymbolIcon People24}"
                                       TargetPageType="{x:Type pages:AthletesPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Команды"
                                       Tag="Clubs"
                                       Icon="{ui:SymbolIcon BuildingTownhouse24}"
                                       TargetPageType="{x:Type pages:ClubsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Возрастные группы"
                                       Tag="AgeGroups"
                                       Icon="{ui:SymbolIcon GroupList24}"
                                       TargetPageType="{x:Type pages:AgeGroupsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Дистанции"
                                       Tag="SwimStyles"
                                       Icon="{ui:SymbolIcon Accessibility24}"
                                       TargetPageType="{x:Type pages:SwimStylesPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="Настройки"
                    Tag="Settings"
                    Icon="{ui:SymbolIcon Settings24}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
        <Border x:Name="ModalOverlay"
                Grid.RowSpan="2"
                Panel.ZIndex="1000"
                Background="#80000000"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>
    </Grid>
</ui:FluentWindow>