<Window x:Class="UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI"
        xmlns:vm="clr-namespace:UI.ViewModels"
        xmlns:views="clr-namespace:UI.Views"
        mc:Ignorable="d"
        Title="SwimDoc" Height="450" Width="800">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CompetitionSelectionViewModel}">
            <views:CompetitionSelectionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventsViewModel}">
            <views:EventsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeatsViewModel}">
            <views:HeatsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EntriesViewModel}">
            <views:EntriesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AthletesViewModel}">
            <views:AthletesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClubsViewModel}">
            <views:ClubsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AgeGroupsViewModel}">
            <views:AgeGroupsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SwimStylesViewModel}">
            <views:SwimStylesView />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Vertical" Grid.Column="0" Margin="10">
            <Button Content="Events" Command="{Binding NavigateToEventsCommand}" Margin="0,5"></Button>
            <Button Content="Heats" Command="{Binding NavigateToHeatsCommand}" Margin="0,5"></Button>
            <Button Content="Entries" Command="{Binding NavigateToEntriesCommand}" Margin="0,5"></Button>
            <Button Content="Athletes" Command="{Binding NavigateToAthletesCommand}" Margin="0,5"></Button>
            <Button Content="Clubs" Command="{Binding NavigateToClubsCommand}" Margin="0,5"></Button>
            <Button Content="Age groups" Command="{Binding NavigateToAgeGroupsCommand}" Margin="0,5"></Button>
            <Button Content="Swim styles" Command="{Binding NavigateToSwimStylesCommand}" Margin="0,5"></Button>
        </StackPanel>
        <ContentControl Content="{Binding CurrentViewModel}" Grid.Column="1" Margin="10"/>
    </Grid>
</Window>
