<UserControl x:Class="UI.Views.Controls.AddEditView.AddEditWindowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d"
             Width="500">
    <Border Background="White" CornerRadius="12">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <!-- Title -->
                <RowDefinition Height="Auto" />
                <!-- Content -->
                <RowDefinition Height="*" />
                <!-- Errors -->
                <RowDefinition Height="Auto" />
                <!-- Buttons -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="Transparent"
                    Cursor="SizeAll"
                    Margin="0,0,0,15"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="{Binding WindowTitle}"
                           FontSize="{StaticResource SwimDocFontSizeSubtitle}"
                           FontWeight="Bold" />
            </Border>

            <ContentControl Grid.Row="1"
                            Content="{Binding EditorContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Margin="0,0,0,15" />

            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding ValidationErrors}"
                          Margin="0,0,0,15">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Foreground="Red"
                                   Text="{Binding}"
                                   TextWrapping="Wrap"
                                   Margin="0,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <UniformGrid Grid.Row="3" HorizontalAlignment="Stretch" Columns="2">
                <ui:Button
                    Padding="5"
                    Margin="5"
                    Appearance="Secondary"
                    Content="{loc:Loc Common_Cancel}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    HorizontalAlignment="Stretch" />
                <ui:Button
                    Padding="5"
                    Margin="5"
                    Appearance="Primary"
                    Content="{loc:Loc Common_Save}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    HorizontalAlignment="Stretch" />
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>