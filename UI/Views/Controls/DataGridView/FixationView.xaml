<UserControl x:Class="UI.Views.Controls.DataGridView.FixationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <dataView:DefaultDataView>
        <dataView:DefaultDataView.Toolbar>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ComboBox helpers:ComboBoxAutoWidthHelper.Enable="True"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedSwimEvent}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,5,6,5" />
                    <ComboBox helpers:ComboBoxAutoWidthHelper.Enable="True"
                              ItemsSource="{Binding EventHeats}"
                              SelectedItem="{Binding SelectedHeat}"
                              DisplayMemberPath="Number"
                              Margin="0,5,6,5" />
                    <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                            Command="{Binding GoToPrevEventCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ChevronLeft20}"
                            Command="{Binding GoToPrevHeatCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ChevronRight24}"
                            Command="{Binding GoToNextHeatCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ArrowNext24}"
                            Command="{Binding GoToNextEventCommand}"
                            Padding="9"
                            Margin="5" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="{ui:SymbolIcon CheckmarkStarburst24}"
                            Command="{Binding ApproveHeatCommand}"
                            IsEnabled="{Binding CanApprove}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon Edit24}"
                            Command="{Binding UnapproveHeatCommand}"
                            IsEnabled="{Binding CanUnapprove}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ArrowClockwise24}"
                            Command="{Binding LoadDataCommand}"
                            ToolTip="Обновить"
                            Margin="0,5,5,5"
                            Padding="9" />
                </StackPanel>
            </DockPanel>
        </dataView:DefaultDataView.Toolbar>
        <dataView:DefaultDataView.MainContent>
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
                    <TextBlock Text="{Binding SelectedHeatHeader}"
                               Margin="5"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SelectedHeatStatus}"
                               Margin="5"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Right" />
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FixationHeatPositionViews}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionUnit="FullRow"
                          RowStyle="{StaticResource DataGridRowLightBlueWhenSelectedStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дорожка" Binding="{Binding Lane}" IsReadOnly="True" Width="80" />
                        <DataGridTextColumn Header="Участник" Binding="{Binding ParticipantName}" IsReadOnly="True"
                                            Width="*" />
                        <DataGridTextColumn Header="Год рождения" Binding="{Binding YearOfBirth}" IsReadOnly="True" Width="110"/>
                        <DataGridTextColumn Header="Клуб" Binding="{Binding Club}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="Заявочное" Binding="{Binding EntryTimeDisplay}" IsReadOnly="True"
                                            Width="100" />

                        <DataGridTemplateColumn Header="Статус" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                                  SelectedItem="{Binding SelectedStatus, UpdateSourceTrigger=PropertyChanged}"
                                                  Visibility="{Binding DataContext.CanEditHeat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding SelectedStatus}"
                                                   Visibility="{Binding DataContext.CanEditHeat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                   VerticalAlignment="Center"
                                                   Padding="6,0" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Результат" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ui:TextBox Text="{Binding FinishTimeText, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="{Binding DataContext.CanEditHeat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding FinishTimeDisplay}"
                                                   Visibility="{Binding DataContext.CanEditHeat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                   VerticalAlignment="Center"
                                                   Padding="6,0" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Очки" Binding="{Binding Points}" IsReadOnly="True" Width="100"/>

                        <DataGridTemplateColumn Header="Примечание" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ui:TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="{Binding DataContext.CanEditHeat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                                    ToolTip="Сохраняется в Comment" />
                                        <TextBlock Text="{Binding Comment}"
                                                   Visibility="{Binding DataContext.CanEditHeat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                   VerticalAlignment="Center"
                                                   Padding="6,0"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </dataView:DefaultDataView.MainContent>
    </dataView:DefaultDataView>
</UserControl>