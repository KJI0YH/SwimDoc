<UserControl x:Class="UI.Views.Controls.DataGridView.HeatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
             xmlns:toolbar="clr-namespace:UI.Views.Controls.Toolbar"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:IntEqualityToBoolConverter x:Key="IntEqualityToBoolConverter" />
    </UserControl.Resources>
    <dataView:DefaultDataView>
        <dataView:DefaultDataView.Toolbar>
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{ui:SymbolIcon Add24}"
                            Command="{Binding CreateHeatCommand}"
                            ToolTip="{loc:Loc Heats_Create}"
                            Margin="5"
                            Padding="9" />
                    <Button Content="{ui:SymbolIcon Edit24}"
                            Command="{Binding EditHeatCommand}"
                            ToolTip="{loc:Loc Heats_Edit}"
                            Margin="5"
                            Padding="9" />
                    <Button Content="{ui:SymbolIcon Delete24}"
                            Command="{Binding DeleteSelectedCommand}"
                            ToolTip="{Binding DeleteToolTip}"
                            Margin="5"
                            Padding="9" />
                    <Button Content="{ui:SymbolIcon ArrowClockwise24}"
                            Command="{Binding RefreshHeatsCommand}"
                            ToolTip="{loc:Loc Heats_Refresh}"
                            Margin="5"
                            Padding="9" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <ComboBox helpers:ComboBoxAutoWidthHelper.Enable="True"
                              ItemsSource="{Binding SwimEventOptions}"
                              SelectedValue="{Binding SelectedSwimEvent}"
                              SelectedValuePath="Value"
                              Margin="0,5,6,5" />
                    <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                            Command="{Binding GoToPrevEventCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ArrowNext24}"
                            Command="{Binding GoToNextEventCommand}"
                            Padding="9"
                            Margin="5" />
                </StackPanel>
                <ui:TextBox VerticalAlignment="Center"
                            Icon="{ui:SymbolIcon Search24}"
                            Margin="5"
                            MinWidth="280"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
        </dataView:DefaultDataView.Toolbar>
        <dataView:DefaultDataView.MainContent>
            <ui:DataGrid ItemsSource="{Binding HeatPositionsView}"
                         SelectedItem="{Binding SelectedHeatPosition}"
                         Margin="5"
                         SelectionChanged="HeatPositionsGrid_SelectionChanged"
                         MouseDoubleClick="HeatPositionsGrid_MouseDoubleClick"
                         AutoGenerateColumns="False"
                         CanUserResizeColumns="True"
                         IsReadOnly="True"
                         SelectionMode="Extended"
                         RowStyle="{StaticResource DataGridRowLightBlueWhenSelectedStyle}"
                         HorizontalAlignment="Stretch"
                         ColumnWidth="*"
                         MinColumnWidth="80"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ui:DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Padding="8,5"
                                        Margin="0,0,0,2"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="HeatGroupHeader_MouseLeftButtonUp">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFE8EEF7" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource IntEqualityToBoolConverter}">
                                                            <Binding Path="Items[0].HeatId" />
                                                            <Binding Path="DataContext.SelectedHeatId"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background"
                                                            Value="{StaticResource DataGridSelectedRowBackgroundBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Path=Items[0].HeatGroupHeader}" />
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ui:DataGrid.GroupStyle>
                <ui:DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc Heats_Col_Lane}" Binding="{Binding Lane}" IsReadOnly="True" Width="90" MinWidth="80" />
                    <DataGridTextColumn Header="{loc:Loc Heats_Col_Participant}" Binding="{Binding Participant}" IsReadOnly="True"
                                        Width="*" MinWidth="220" />
                    <DataGridTextColumn Header="{loc:Loc Heats_Col_BirthYear}" Binding="{Binding YearOfBirth}" IsReadOnly="True"
                                        Width="140" MinWidth="120" />
                    <DataGridTextColumn Header="{loc:Loc Heats_Col_Team}" Binding="{Binding Club}" IsReadOnly="True" Width="*"
                                        MinWidth="220" />
                    <DataGridTextColumn Header="{loc:Loc Heats_Col_EntryTime}" Binding="{Binding EntryTime}" IsReadOnly="True"
                                        Width="160" MinWidth="140" />
                    <DataGridTextColumn Header="{loc:Loc Heats_Col_Result}" Binding="{Binding FinishTime}" IsReadOnly="True"
                                        Width="160" MinWidth="140" />
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </dataView:DefaultDataView.MainContent>
    </dataView:DefaultDataView>
</UserControl>