<UserControl x:Class="UI.Views.Controls.DataGridView.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
             xmlns:displayHelpers="clr-namespace:UI.Helpers.Display"
             xmlns:converters="clr-namespace:UI.Helpers.Converters"
             xmlns:uiHelpers="clr-namespace:UI.Helpers.Controls"
             xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <dataView:DefaultDataView>
        <dataView:DefaultDataView.Toolbar>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ComboBox uiHelpers:ComboBoxAutoWidthHelper.Enable="True"
                              ItemsSource="{Binding SwimEventOptions}"
                              SelectedValue="{Binding SelectedSwimEvent}"
                              SelectedValuePath="Value"
                              Margin="0,5,6,5" />
                    <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                            Command="{Binding GoToPrevEventCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ArrowNext24}"
                            Command="{Binding GoToNextEventCommand}"
                            Padding="9"
                            Margin="5" />
                </StackPanel>
            </DockPanel>
        </dataView:DefaultDataView.Toolbar>
        <dataView:DefaultDataView.MainContent>

            <ui:DataGrid ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedResultEntry}"
                      MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      RowStyle="{StaticResource DataGridRowResultsPlaceStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Localizastion Results_Col_Place}" Binding="{Binding Place}" IsReadOnly="True" Width="80" />
                    <DataGridTextColumn Header="{loc:Localizastion Results_Col_Participant}" Binding="{Binding ParticipantName}" IsReadOnly="True"
                                        Width="*" />
                    <DataGridTextColumn Header="{loc:Localizastion Fixation_Col_BirthYear}" Binding="{Binding ParticipantYearOfBirth}"
                                        IsReadOnly="True" Width="120" />
                    <DataGridTextColumn Header="{loc:Localizastion Results_Col_Team}" Binding="{Binding ClubName}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="{loc:Localizastion Results_Col_Result}" Binding="{Binding ResultText}" IsReadOnly="True"
                                        Width="150" />
                    <DataGridTextColumn Header="{loc:Localizastion Results_Col_Points}" Binding="{Binding Points}" IsReadOnly="True" Width="150" />
                </DataGrid.Columns>
            </ui:DataGrid>
        </dataView:DefaultDataView.MainContent>
    </dataView:DefaultDataView>
</UserControl>