<UserControl x:Class="UI.Views.Controls.DataGridView.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <dataView:DefaultDataView>
        <dataView:DefaultDataView.Toolbar>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ComboBox helpers:ComboBoxAutoWidthHelper.Enable="True"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedSwimEvent}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,5,6,5" />
                    <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                            Command="{Binding GoToPrevEventCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ArrowNext24}"
                            Command="{Binding GoToNextEventCommand}"
                            Padding="9"
                            Margin="5" />
                </StackPanel>
            </DockPanel>
        </dataView:DefaultDataView.Toolbar>
        <dataView:DefaultDataView.MainContent>

            <DataGrid ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedResultEntry}"
                      MouseDoubleClick="ResultsGrid_MouseDoubleClick"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionUnit="FullRow"
                      RowStyle="{StaticResource DataGridRowResultsPlaceStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Место" Binding="{Binding Place}" IsReadOnly="True" Width="80" />
                    <DataGridTextColumn Header="Участник" Binding="{Binding ParticipantName}" IsReadOnly="True"
                                        Width="*" />
                    <DataGridTextColumn Header="Год рождения" Binding="{Binding ParticipantYearOfBirth}"
                                        IsReadOnly="True" Width="120" />
                    <DataGridTextColumn Header="Команда" Binding="{Binding ClubName}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="Результат" Binding="{Binding ResultText}" IsReadOnly="True"
                                        Width="150" />
                    <DataGridTextColumn Header="Очки" Binding="{Binding Points}" IsReadOnly="True" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </dataView:DefaultDataView.MainContent>
    </dataView:DefaultDataView>
</UserControl>