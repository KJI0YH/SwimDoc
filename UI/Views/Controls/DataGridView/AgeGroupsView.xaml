<UserControl x:Class="UI.Views.Controls.DataGridView.AgeGroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
             xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView"
             xmlns:toolbar="clr-namespace:UI.Views.Controls.Toolbar"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             xmlns:operationInfoBar="clr-namespace:UI.Views.Controls.OperationInfoBar"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <dataView:DefaultDataView>
            <dataView:DefaultDataView.Toolbar>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Content="{ui:SymbolIcon Print24}"
                                ToolTip="{loc:Localizastion AgeGroups_GenerateCombinedResultsReports}"
                                Command="{Binding GenerateCombinedResultsReportsCommand}"
                                Margin="5"
                                Padding="9" />
                    </StackPanel>
                    <toolbar:DefaultToolbar DockPanel.Dock="Top" />
                </DockPanel>
            </dataView:DefaultDataView.Toolbar>
            <dataView:DefaultDataView.MainContent>
                <dataGridView:DataGridView />
            </dataView:DefaultDataView.MainContent>
        </dataView:DefaultDataView>

        <operationInfoBar:OperationInfoBar Margin="10"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Stretch"
                                           Panel.ZIndex="1000" />
    </Grid>
</UserControl>
