<UserControl x:Class="UI.Views.Controls.DataGridView.CombinedResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
             xmlns:displayHelpers="clr-namespace:UI.Helpers.Display"
             xmlns:converters="clr-namespace:UI.Helpers.Converters"
             xmlns:uiHelpers="clr-namespace:UI.Helpers.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="CombinedResultsRowStyle"
               TargetType="DataGridRow"
               BasedOn="{StaticResource DataGridRowResultsPlaceStyle}" />
    </UserControl.Resources>
    <dataView:DefaultDataView>
        <dataView:DefaultDataView.Toolbar>
            <DockPanel Visibility="{Binding ShowAgeGroupSelector, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ComboBox uiHelpers:ComboBoxAutoWidthHelper.Enable="True"
                              ItemsSource="{Binding AgeGroupOptions}"
                              SelectedValue="{Binding SelectedAgeGroup}"
                              SelectedValuePath="Value"
                              Margin="0,5,6,5" />
                    <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                            Command="{Binding GoToPrevAgeGroupCommand}"
                            Padding="9"
                            Margin="5" />
                    <Button Content="{ui:SymbolIcon ArrowNext24}"
                            Command="{Binding GoToNextAgeGroupCommand}"
                            Padding="9"
                            Margin="5" />
                </StackPanel>
            </DockPanel>
        </dataView:DefaultDataView.Toolbar>
        <dataView:DefaultDataView.MainContent>
            <ui:DataGrid ItemsSource="{Binding Rows}"
                         SelectedItem="{Binding SelectedRow}"
                         MouseDoubleClick="CombinedResultsGrid_MouseDoubleClick"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         Loaded="CombinedResultsGrid_Loaded"
                         RowStyle="{StaticResource CombinedResultsRowStyle}" />
        </dataView:DefaultDataView.MainContent>
    </dataView:DefaultDataView>
</UserControl>
