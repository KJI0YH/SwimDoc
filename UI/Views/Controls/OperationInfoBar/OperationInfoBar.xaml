<UserControl x:Class="UI.Views.Controls.OperationInfoBar.OperationInfoBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:media="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:IntGreaterThanZeroConverter x:Key="IntGt0" />
        <helpers:EnumDescriptionConverter x:Key="EnumDescription" />
        <helpers:RectHeightConverter x:Key="RectHeight" />
        <helpers:LocalizedStringFormatConverter x:Key="LocFormat" />
        <Style x:Key="OperationStatsCellTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="OperationStatsColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Padding="10"
            CornerRadius="10"
            Background="#F2FFFFFF"
            Visibility="{Binding IsOperationBarOpen, Converter={StaticResource BoolToVis}}">
        <Border.Effect>
            <media:DropShadowEffect BlurRadius="14" Opacity="0.25" ShadowDepth="2" />
        </Border.Effect>

        <StackPanel>
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button ToolTip="{loc:Loc Import_Details}"
                            Margin="5,0,0,0"
                            Padding="9"
                            Command="{Binding ToggleOperationDetailsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="{ui:SymbolIcon ChevronDown24}" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOperationDetailsOpen}" Value="True">
                                        <Setter Property="Content" Value="{ui:SymbolIcon ChevronUp24}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CanToggleOperationDetails}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{ui:SymbolIcon Stop24}"
                            ToolTip="{loc:Loc Import_Cancel}"
                            Margin="5,0,0,0"
                            Padding="9"
                            Command="{Binding CancelOperationCommand}"
                            Visibility="{Binding IsOperationRunning, Converter={StaticResource BoolToVis}}" />

                    <Button ToolTip="{loc:Loc Import_Close}"
                            Margin="5,0,0,0"
                            Padding="9"
                            Command="{Binding DismissOperationBarCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="{ui:SymbolIcon Dismiss24}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOperationRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="{Binding OperationHeader}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding OperationMessage}" Opacity="0.8" />
                    <ProgressBar Margin="0,8,0,0"
                                 IsIndeterminate="{Binding IsOperationRunning}"
                                 Minimum="0"
                                 Maximum="{Binding OperationTotalItems}"
                                 Value="{Binding OperationProcessedItems}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar"
                                   BasedOn="{StaticResource SwimDocAccentProgressBarStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOperationRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
            </DockPanel>

            <Border Margin="0,10,0,0"
                    MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Converter={StaticResource RectHeight}, ConverterParameter=0.55}"
                    ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsOperationDetailsOpen}" Value="True" />
                                    <Condition Binding="{Binding IsMultiItemOperation}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ui:DataGrid ItemsSource="{Binding OperationItems}"
                                 AutoGenerateColumns="False"
                                 CanUserDeleteRows="False"
                                 IsReadOnly="True"
                                 SelectionMode="Single"
                                 RowDetailsVisibilityMode="Visible"
                                 PreviewMouseLeftButtonDown="ItemsGrid_PreviewMouseLeftButtonDown"
                                 LoadingRow="ItemsGrid_LoadingRow"
                                 x:Name="ItemsGrid">
                        <ui:DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding WarningsCount, Converter={StaticResource IntGt0}}"
                                                    Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger
                                                    Binding="{Binding ErrorsCount, Converter={StaticResource IntGt0}}"
                                                    Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <GroupBox Margin="0,0,0,8">
                                        <GroupBox.Style>
                                            <Style TargetType="GroupBox">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WarningsCount}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </GroupBox.Style>
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <ContentControl Content="{ui:SymbolIcon Warning24}"
                                                                Foreground="#D97706"
                                                                Margin="0,0,6,0" />
                                                <TextBlock Foreground="#D97706"
                                                           Text="{Binding WarningsCount, Converter={StaticResource LocFormat}, ConverterParameter=Import_WarningsFormat}" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Warnings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </GroupBox>

                                    <GroupBox>
                                        <GroupBox.Style>
                                            <Style TargetType="GroupBox">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ErrorsCount}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </GroupBox.Style>
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <ContentControl Content="{ui:SymbolIcon ErrorCircle24}"
                                                                Foreground="#B91C1C"
                                                                Margin="0,0,6,0" />
                                                <TextBlock Foreground="#B91C1C"
                                                           Text="{Binding ErrorsCount, Converter={StaticResource LocFormat}, ConverterParameter=Import_ErrorsFormat}" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Errors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </GroupBox>
                                </StackPanel>
                            </DataTemplate>
                        </ui:DataGrid.RowDetailsTemplate>
                        <ui:DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc Operation_Col_Event}"
                                                Binding="{Binding EventName}"
                                                Width="*" />
                            <DataGridTextColumn Header="{loc:Loc Import_Col_Status}"
                                                Width="200"
                                                Binding="{Binding Status, Converter={StaticResource EnumDescription}}" />
                            <DataGridTextColumn Header="{loc:Loc Operation_Col_HeatsCreated}"
                                                Binding="{Binding HeatsCreatedDisplay}"
                                                Width="120"
                                                ElementStyle="{StaticResource OperationStatsCellTextStyle}"
                                                HeaderStyle="{StaticResource OperationStatsColumnHeaderStyle}" />
                            <DataGridTemplateColumn Header="{loc:Loc Import_Col_Warnings}" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                                                   Text="{Binding WarningsCount}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{loc:Loc Import_Col_Errors}" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                                                   Text="{Binding ErrorsCount}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </ui:DataGrid.Columns>
                    </ui:DataGrid>
                </ScrollViewer>
            </Border>

            <Border Margin="0,10,0,0"
                    MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Converter={StaticResource RectHeight}, ConverterParameter=0.35}"
                    ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsOperationDetailsOpen}" Value="True" />
                                    <Condition Binding="{Binding IsMultiItemOperation}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <GroupBox>
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{ui:SymbolIcon ErrorCircle24}"
                                            Foreground="#B91C1C"
                                            Margin="0,0,6,0" />
                            <TextBlock Foreground="#B91C1C"
                                       Text="{Binding OperationErrors.Count, Converter={StaticResource LocFormat}, ConverterParameter=Import_ErrorsFormat}" />
                        </StackPanel>
                    </GroupBox.Header>
                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding OperationErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
