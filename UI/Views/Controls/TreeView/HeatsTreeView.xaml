<UserControl x:Class="UI.Views.Controls.TreeView.HeatsTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:efClasses="clr-namespace:DataLayer.EfClasses;assembly=DataLayer"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <TreeView x:Name="TvHeats"
              ItemsSource="{Binding Items}"
              SelectedItemChanged="TreeView_OnSelectedItemChanged"
              Grid.IsSharedSizeScope="True"
              ScrollViewer.CanContentScroll="True"
              ScrollViewer.HorizontalScrollBarVisibility="Auto"
              ScrollViewer.VerticalScrollBarVisibility="Auto">
        <TreeView.InputBindings>
            <KeyBinding Key="Delete" Command="{Binding DeleteItemCommand}" />
        </TreeView.InputBindings>
        <TreeView.Resources>
            <HierarchicalDataTemplate DataType="{x:Type efClasses:SwimEvent}"
                                      ItemsSource="{Binding Heats}">
                <Grid HorizontalAlignment="Stretch" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SwimEventNameGroup" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SwimEventDateGroup" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SwimEventTimeGroup" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding DisplayName}"
                               Margin="18,0,100,0"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplayDate, StringFormat=Дата: {0}}"
                               Margin="0,0,100,0"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Time, StringFormat=Старт: {0}}"
                               Margin="0,0,100,0"
                               FontWeight="SemiBold" />
                </Grid>
            </HierarchicalDataTemplate>
            <HierarchicalDataTemplate DataType="{x:Type efClasses:Heat}"
                                      ItemsSource="{Binding Positions}">
                <Grid HorizontalAlignment="Stretch" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SwimEventNameGroup" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SwimEventDateGroup" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SwimEventTimeGroup" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               TextDecorations="Underline"
                               FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}Заплыв {0} из {1} ({2} из {3})">
                                <Binding Path="Number" />
                                <Binding Path="TotalHeatsInEvent" />
                                <Binding Path="Order" />
                                <Binding Path="DataContext.TotalHeats"
                                         RelativeSource="{RelativeSource AncestorType=TreeView}" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SwimEvent.DisplayDate, StringFormat=Дата: {0}}"
                               FontWeight="SemiBold"
                               Margin="-18,0,0,0" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding DayTime, StringFormat=Старт: {0}}"
                               FontWeight="SemiBold"
                               Margin="-18,0,0,0" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Status}"
                               FontWeight="SemiBold" />
                </Grid>
            </HierarchicalDataTemplate>

            <DataTemplate DataType="{x:Type efClasses:HeatPosition}">
                <Grid Margin="5" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LaneColumn" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ParticipantColumn" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="YearOfBirthColumn" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ClubColumn" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="EntryTimeColumn" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="FinishTimeColumn" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,0,20,0" Text="{Binding Lane}" />
                    <TextBlock Grid.Column="1" Margin="0,0,50,0" Text="{Binding Entry.Athlete.DisplayName}" />
                    <TextBlock Grid.Column="2" Margin="0,0,50,0" Text="{Binding Entry.Athlete.YearOfBirth}" />
                    <TextBlock Grid.Column="3" Margin="0,0,100,0" Text="{Binding Entry.Athlete.DisplayClubName}" />
                    <TextBlock Grid.Column="4" Margin="0,0,50,0" Text="{Binding Entry.DisplayEntryTime}" />
                    <TextBlock Grid.Column="5" Text="{Binding Entry.DisplayFinishTime}" />
                </Grid>
            </DataTemplate>
        </TreeView.Resources>
    </TreeView>
</UserControl>