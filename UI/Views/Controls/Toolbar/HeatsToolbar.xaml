<UserControl x:Class="UI.Views.Controls.Toolbar.HeatsToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:displayHelpers="clr-namespace:UI.Helpers.Display"
             xmlns:converters="clr-namespace:UI.Helpers.Converters"
             xmlns:uiHelpers="clr-namespace:UI.Helpers.Controls"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Content="{ui:SymbolIcon Add24}"
                    Command="{Binding CreateHeatCommand}"
                    ToolTip="{loc:Localizastion Heats_Create}"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon Edit24}"
                    Command="{Binding EditHeatCommand}"
                    ToolTip="{loc:Localizastion Heats_Edit}"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon Delete24}"
                    Command="{Binding DeleteSelectedCommand}"
                    ToolTip="{Binding DeleteToolTip}"
                    Margin="5"
                    Padding="9" />
        </StackPanel>

        <ui:TextBox Grid.Column="1"
                    VerticalAlignment="Center"
                    Icon="{ui:SymbolIcon Search24}"
                    Margin="5"
                    MinWidth="280"
                    HorizontalAlignment="Stretch"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <ComboBox Style="{StaticResource SwimDocSwimEventComboBoxStyle}"
                      ItemsSource="{Binding SwimEventOptions}"
                      SelectedValue="{Binding SelectedSwimEvent}"
                      SelectedValuePath="Value"
                      Margin="0,5,6,5" />
            <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                    Command="{Binding GoToPrevEventCommand}"
                    Padding="9"
                    Margin="5" />
            <Button Content="{ui:SymbolIcon ArrowNext24}"
                    Command="{Binding GoToNextEventCommand}"
                    Padding="9"
                    Margin="5" />
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="{Binding HeatsItemsInfo}"
                       Margin="5"
                       VerticalAlignment="Center" />
            <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                    Command="{Binding GoToFirstHeatPageCommand}"
                    ToolTip="{loc:Localizastion Paging_First}"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon ChevronLeft24}"
                    Command="{Binding GoToPreviousHeatPageCommand}"
                    ToolTip="{loc:Localizastion Paging_Previous}"
                    Margin="5"
                    Padding="9" />
            <ComboBox IsEditable="True"
                      Margin="5"
                      IsEnabled="{Binding IsHeatPagingEnabled}"
                      ItemsSource="{Binding HeatPageOptions}"
                      SelectedIndex="{Binding HeatCurrentPage, Mode=TwoWay}"
                      uiHelpers:PageComboBoxBehavior.Enable="True"
                      uiHelpers:PageComboBoxBehavior.TotalPages="{Binding HeatTotalPages}"
                      uiHelpers:PageComboBoxBehavior.CurrentPage="{Binding HeatCurrentPage, Mode=TwoWay}" />
            <Button Content="{ui:SymbolIcon ChevronRight24}"
                    Command="{Binding GoToNextHeatPageCommand}"
                    ToolTip="{loc:Localizastion Paging_Next}"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon ArrowNext24}"
                    Command="{Binding GoToLastHeatPageCommand}"
                    ToolTip="{loc:Localizastion Paging_Last}"
                    Margin="5"
                    Padding="9" />
        </StackPanel>
    </Grid>
</UserControl>
