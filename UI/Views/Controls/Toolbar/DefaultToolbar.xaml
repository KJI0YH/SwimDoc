<UserControl x:Class="UI.Views.Controls.Toolbar.DefaultToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:UI.Helpers"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Content="{ui:SymbolIcon Add24}"
                    Command="{Binding CreateItemCommand}"
                    ToolTip="Создать"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon Edit24}"
                    Command="{Binding EditItemCommand}"
                    ToolTip="Редактировать"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon Delete24}"
                    Command="{Binding DeleteItemCommand}"
                    ToolTip="Удалить"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon ArrowClockwise24}"
                    Command="{Binding LoadDataCommand}"
                    ToolTip="Обновить"
                    Margin="5"
                    Padding="9" />
        </StackPanel>

        <ui:TextBox Grid.Column="1"
                    VerticalAlignment="Center"
                    Icon="{ui:SymbolIcon Search24}"
                    Margin="5"
                    MinWidth="320"
                    HorizontalAlignment="Stretch"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock
                    Text="{Binding ItemsInfo}"
                    Margin="5"
                    VerticalAlignment="Center"/>
            <Button Content="{ui:SymbolIcon ArrowPrevious24}"
                    Command="{Binding GoToFirstPageCommand}"
                    ToolTip="Первая страница"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon ChevronLeft24}"
                    Command="{Binding GoToPreviousPageCommand}"
                    ToolTip="Предыдущая страница"
                    Margin="5"
                    Padding="9" />
            <ComboBox
                IsEditable="True"
                Margin="5"
                IsEnabled="{Binding IsPagingEnabled}"
                ItemsSource="{Binding PageOptions}"
                SelectedIndex="{Binding CurrentPage, Mode=TwoWay}"
                helpers:PageComboBoxBehavior.Enable="True"
                helpers:PageComboBoxBehavior.TotalPages="{Binding TotalPages}"
                helpers:PageComboBoxBehavior.CurrentPage="{Binding CurrentPage, Mode=TwoWay}" />
            <Button Content="{ui:SymbolIcon ChevronRight24}"
                    Command="{Binding GoToNextPageCommand}"
                    ToolTip="Следующая страница"
                    Margin="5"
                    Padding="9" />
            <Button Content="{ui:SymbolIcon ArrowNext24}"
                    Command="{Binding GoToLastPageCommand}"
                    ToolTip="Последняя страница"
                    Margin="5"
                    Padding="9" />
        </StackPanel>
    </Grid>
</UserControl>