<UserControl x:Class="UI.Views.Controls.SearchableComboBox.SearchableComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="30" d:DesignWidth="300">
    <Grid>
        <ComboBox x:Name="ComboBoxControl"
                  IsEditable="True"
                  IsTextSearchEnabled="False"
                  StaysOpenOnEdit="True"
                  PreviewKeyDown="ComboBoxControl_OnPreviewKeyDown"
                  PreviewTextInput="ComboBoxControl_OnPreviewTextInput"
                  DropDownOpened="ComboBoxControl_OnDropDownOpened"
                  TextBoxBase.TextChanged="ComboBoxControl_OnTextChanged"
                  SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                  DisplayMemberPath="{Binding DisplayMemberPath, ElementName=Root}" />
    </Grid>
</UserControl>