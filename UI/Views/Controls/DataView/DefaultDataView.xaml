<UserControl x:Class="UI.Views.Controls.DataView.DefaultDataView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:toolbar="clr-namespace:UI.Views.Controls.Toolbar"
             xmlns:converters="clr-namespace:UI.Helpers.Converters"
             xmlns:loc="clr-namespace:UI.Localization"
             ScrollViewer.VerticalScrollBarVisibility="Disabled"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ContentPresenter Grid.Row="0"
                          Content="{Binding ElementName=Root, Path=Toolbar}"
                          Margin="5">
            <ContentPresenter.Style>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=Root, Path=Toolbar}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentPresenter.Style>
        </ContentPresenter>

        <toolbar:DefaultToolbar Grid.Row="0" Margin="5">
            <toolbar:DefaultToolbar.Style>
                <Style TargetType="toolbar:DefaultToolbar">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=Root, Path=Toolbar}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </toolbar:DefaultToolbar.Style>
        </toolbar:DefaultToolbar>

        <Grid Grid.Row="1">
            <ContentPresenter Content="{Binding ElementName=Root, Path=MainContent}" />

            <Border Background="#CCFFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MinWidth="220">
                    <ProgressBar IsIndeterminate="True"
                                 Height="4"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource SwimDocAccentProgressBarStyle}" />
                    <TextBlock Text="{loc:Localizastion Common_LoadingData}"
                               HorizontalAlignment="Center"
                               Opacity="0.85" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>