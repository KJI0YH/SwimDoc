<Window x:Class="UI.Views.AddEdit.SwimStyleAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UI.Helpers"
        xmlns:generic="clr-namespace:UI.Views.Generic"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <helpers:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </Window.Resources>
    <generic:AddEditWindowLayout>
        <StackPanel Margin="0,0,0,15">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Стиль"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding StrokeValues}"
                          SelectedItem="{Binding Stroke}"
                          Margin="0,2,0,2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Дистанция"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          IsEditable="True"
                          Text="{Binding Path=Distance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValue="{Binding Distance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemsSource>
                        <x:Array Type="{x:Type system:Int32}">
                            <system:Int32>50</system:Int32>
                            <system:Int32>100</system:Int32>
                            <system:Int32>200</system:Int32>
                            <system:Int32>400</system:Int32>
                            <system:Int32>800</system:Int32>
                            <system:Int32>1500</system:Int32>
                        </x:Array>
                    </ComboBox.ItemsSource>
                </ComboBox>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Участников эстафеты"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:NumberBox Grid.Column="1"
                              PlaceholderText="Individual"
                              Value="{Binding RelayCount, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,2,0,2" />

            </Grid>
        </StackPanel>
    </generic:AddEditWindowLayout>
</Window>