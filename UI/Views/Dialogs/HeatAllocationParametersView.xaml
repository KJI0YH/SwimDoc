<UserControl x:Class="UI.Views.Dialogs.HeatAllocationParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:heatLogic="clr-namespace:BizLogic.HeatLogic;assembly=BizLogic"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d">
    <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
    
                <Grid Grid.Row="0" Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc HeatAlloc_Field_Order}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ComboBox Grid.Column="1"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding SelectedHeatOrder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="{loc:Loc HeatAlloc_Order_WeakToStrong}"
                                      Tag="{x:Static heatLogic:HeatOrder.FromWeakToStrong}" />
                        <ComboBoxItem Content="{loc:Loc HeatAlloc_Order_StrongToWeak}"
                                      Tag="{x:Static heatLogic:HeatOrder.FromStrongToWeak}" />
                    </ComboBox>
                </Grid>
    
                <Grid Grid.Row="1" Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc HeatAlloc_Field_MinHeatSize}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ui:NumberBox Grid.Column="1"
                                  Minimum="1"
                                  Value="{Binding MinHeatSize, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
</UserControl>
