<UserControl x:Class="UI.Views.Dialogs.LoadEntriesFromPreviousEventView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:searchableComboBox="clr-namespace:UI.Views.Controls.SearchableComboBox"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d">
    <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
    
                <Grid Grid.Row="0" Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc LoadPrev_Field_PreviousEvent}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <searchableComboBox:SearchableComboBox Grid.Column="1"
                                                           ItemsSource="{Binding OfficialPreviousEvents}"
                                                           SelectedItem="{Binding SelectedPreviousEvent, Mode=TwoWay}"
                                                           Margin="0,2,0,2" />
                </Grid>
    
                <Grid Grid.Row="1" Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc LoadPrev_Field_CurrentEvent}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               TextWrapping="Wrap" />
                    <searchableComboBox:SearchableComboBox Grid.Column="1"
                                                           ItemsSource="{Binding TargetEvents}"
                                                           SelectedItem="{Binding SelectedTargetEvent, Mode=TwoWay}"
                                                           Margin="0,2,0,2" />
                </Grid>
            </Grid>
</UserControl>
