<UserControl x:Class="UI.Views.Dialogs.AddEdit.AthleteAddEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:controls="clr-namespace:UI.Views.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:searchableComboBox="clr-namespace:UI.Views.Controls.SearchableComboBox"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d">
    <StackPanel Margin="0,0,0,15">
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Athlete_Field_FirstName}"
                               Style="{StaticResource DialogFieldLabelStyle}" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Athlete_Field_LastName}"
                               Style="{StaticResource DialogFieldLabelStyle}" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Athlete_Field_Gender}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding GenderOptions}"
                              SelectedValue="{Binding Gender}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Athlete_Field_BirthYear}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ui:NumberBox Grid.Column="1"
                                  Value="{Binding YearOfBirth, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Athlete_Field_Category}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding CategoryOptions}"
                              SelectedValue="{Binding Category}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Athlete_Field_Club}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <searchableComboBox:SearchableComboBox Grid.Column="1"
                                                 ItemsSource="{Binding Clubs}"
                                                 SelectedItem="{Binding SelectedClub, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2,0,2" />
                    <Button Grid.Column="2"
                            Content="{ui:SymbolIcon Add24}"
                            Command="{Binding CreateNewClubCommand}"
                            Margin="5,2,0,2"
                            Padding="9" />
                </Grid>
            </StackPanel>
</UserControl>
