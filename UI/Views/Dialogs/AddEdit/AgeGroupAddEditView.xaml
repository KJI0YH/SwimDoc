<UserControl x:Class="UI.Views.Dialogs.AddEdit.AgeGroupAddEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:UI.Localization"
             mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:NullableIntConverter x:Key="NullableIntConverter" />
    </UserControl.Resources>
    <StackPanel Margin="0,0,0,15">
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Localizastion Field_Name}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="{loc:Localizastion Common_Auto}"
                                Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Localizastion Athlete_Field_Gender}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding GenderOptions}"
                              SelectedValue="{Binding Gender}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              Margin="0,2,0,2" />
                </Grid>
    
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{loc:Localizastion Athlete_Field_BirthYear}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <UniformGrid Grid.Column="1" Columns="2">
                        <ui:NumberBox PlaceholderText="{loc:Localizastion Common_AbsoluteMin}"
                                      Value="{Binding BirthYearMin, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}, TargetNullValue=''}"
                                      Margin="0,2,2,2"
                                      Minimum="1900" />
                        <ui:NumberBox PlaceholderText="{loc:Localizastion Common_AbsoluteMax}"
                                      Value="{Binding BirthYearMax, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}, TargetNullValue=''}"
                                      Margin="2, 2, 0, 2"
                                      Minimum="1900" />
                    </UniformGrid>
                </Grid>
            </StackPanel>
</UserControl>
