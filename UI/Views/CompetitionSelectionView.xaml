<UserControl x:Class="UI.Views.CompetitionSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="500">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Создать новое соревнование"
                Command="{Binding CreateNewCommand}" 
                Padding="15,10" Margin="0,0,0,15" FontSize="14"/>
        
        <Button Grid.Row="1" Content="Открыть существующее соревнование"
                Command="{Binding OpenExistingCommand}" 
                Padding="15,10" FontSize="14" VerticalAlignment="Top"/>
    </Grid>
</UserControl>

