<Page x:Class="UI.Views.Pages.ClubDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ScrollViewer.CanContentScroll="False"
      xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
      xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="Спортсмены">
                <dataGridView:AthletesView DataContext="{Binding AthletesTable}"/>
            </TabItem>
            <TabItem Header="Заявки">
                <dataView:DefaultDataView DataContext="{Binding EntriesTable}">
                    <dataView:DefaultDataView.MainContent>
                        <dataGridView:DataGridView />
                    </dataView:DefaultDataView.MainContent>
                </dataView:DefaultDataView>
            </TabItem>
        </TabControl>
    </Grid>
</Page>