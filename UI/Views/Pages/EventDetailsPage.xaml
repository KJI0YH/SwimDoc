<Page x:Class="UI.Views.Pages.EventDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ScrollViewer.CanContentScroll="False"
      xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
      xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView"
      xmlns:treeView="clr-namespace:UI.Views.Controls.TreeView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="Заявки">
                <dataGridView:EntriesView DataContext="{Binding EntriesTable}" />
            </TabItem>
            <TabItem Header="Заплывы"
                     Style="{StaticResource SwimTabItemSelectedGrayStyle}">
                <dataGridView:HeatsView DataContext="{Binding HeatsTable}" />
            </TabItem>
            <TabItem Header="Фиксация"
                     Style="{StaticResource SwimTabItemSelectedGrayStyle}">
                <dataGridView:HeatsResultsView DataContext="{Binding FixationTable}" />
            </TabItem>
            <TabItem Header="Результаты"
                     Style="{StaticResource SwimTabItemSelectedGrayStyle}">
                <dataGridView:ResultsView DataContext="{Binding ResultsTable}" />
            </TabItem>
        </TabControl>
    </Grid>
</Page>