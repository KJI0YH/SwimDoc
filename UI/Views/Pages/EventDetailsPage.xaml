<Page x:Class="UI.Views.Pages.EventDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ScrollViewer.CanContentScroll="False"
      xmlns:loc="clr-namespace:UI.Localization"
      xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
      xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="1" Margin="5" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="{loc:Localizastion Tabs_Entries}">
                <dataGridView:EntriesView DataContext="{Binding EntriesTable}" />
            </TabItem>
            <TabItem Header="{loc:Localizastion Tabs_Heats}">
                <dataGridView:HeatsView DataContext="{Binding HeatsTable}" />
            </TabItem>
            <TabItem Header="{loc:Localizastion Tabs_Fixation}">
                <dataGridView:FixationView DataContext="{Binding FixationTable}" />
            </TabItem>
            <TabItem Header="{loc:Localizastion Tabs_Results}">
                <dataGridView:ResultsView DataContext="{Binding ResultsTable}" />
            </TabItem>
        </TabControl>
    </Grid>
</Page>