<Page x:Class="UI.Views.Pages.AgeGroupDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ScrollViewer.CanContentScroll="False"
      xmlns:loc="clr-namespace:UI.Localization"
      xmlns:dataView="clr-namespace:UI.Views.Controls.DataView"
      xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TabControl Margin="5" Grid.Row="1">
            <TabItem Header="{loc:Localizastion Tabs_Athletes}">
                <dataGridView:AthletesView DataContext="{Binding AthletesTable}" />
            </TabItem>
            <TabItem Header="{loc:Localizastion Tabs_Events}">
                <dataGridView:EventsView DataContext="{Binding EventsTable}"/>
            </TabItem>
            <TabItem Header="{loc:Localizastion Tabs_CombinedResults}">
                <dataGridView:CombinedResultsView DataContext="{Binding CombinedResultsTable}" />
            </TabItem>
        </TabControl>
    </Grid>
</Page>