<Page x:Class="UI.Views.Pages.AthleteDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ScrollViewer.CanContentScroll="False"
      xmlns:loc="clr-namespace:UI.Localization"
      xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="1" Margin="5" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="{loc:Loc Tabs_Entries}">
                <dataGridView:EntriesView DataContext="{Binding EntriesTable}"
                                          ShowImportActions="False" />
            </TabItem>
            <TabItem Header="{loc:Loc Tabs_Heats}">
                <dataGridView:HeatsView DataContext="{Binding HeatsTable}" />
            </TabItem>
            <TabItem Header="{loc:Loc Tabs_Results}">
                <dataGridView:ParticipantResultsView DataContext="{Binding ResultsTable}" />
            </TabItem>
        </TabControl>
    </Grid>
</Page>
