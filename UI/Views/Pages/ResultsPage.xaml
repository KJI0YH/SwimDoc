<Page x:Class="UI.Views.Pages.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ScrollViewer.CanContentScroll="False"
      xmlns:loc="clr-namespace:UI.Localization"
      xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView">
    <TabControl Margin="5">
        <TabItem Header="{loc:Loc Tabs_Results}">
            <dataGridView:ResultsView />
        </TabItem>
        <TabItem Header="{loc:Loc Tabs_CombinedResults}">
            <dataGridView:CombinedResultsView DataContext="{Binding CombinedResults}" />
        </TabItem>
    </TabControl>
</Page>
