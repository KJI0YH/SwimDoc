<Page x:Class="UI.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24">
        <StackPanel MaxWidth="720"
                    HorizontalAlignment="Center">
            <Border Width="96"
                    Height="96"
                    CornerRadius="22"
                    Margin="0,16,0,20"
                    HorizontalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="#FF1565C0" />
                </Border.Background>
                <ui:SymbolIcon Symbol="SwimmingPool24"
                               Foreground="White"
                               FontSize="52"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>

            <TextBlock Style="{StaticResource TitleLargeTextBlockStyle}"
                       Text="{Binding ApplicationName}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock Margin="0,6,0,28"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding VersionText}" />

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                       Text="{Binding AuthorSectionTitle}"
                       Margin="0,0,0,12" />
            <Border Style="{StaticResource SettingsCardBorderStyle}"
                    Margin="0,0,0,28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SettingsIconBadgeStyle}">
                        <ui:SymbolIcon Symbol="Person24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                   FontSize="{StaticResource SwimDocFontSizeBody}"
                                   Text="{Binding AuthorName}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding AuthorLocation}" />
                        <Border Height="1"
                                Margin="0,14,0,12"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding CopyrightText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                       Text="{Binding SupportSectionTitle}"
                       Margin="0,0,0,12" />
            <Border Style="{StaticResource SettingsCardBorderStyle}"
                    Margin="0,0,0,28">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding SupportDescription}" />
                    <UniformGrid Columns="2"
                                 Margin="0,16,0,0">
                        <ui:Button Appearance="Primary"
                                   Margin="0,0,6,0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Command="{Binding OpenEmailCommand}"
                                   Content="{Binding OpenEmailLabel}" />
                        <ui:Button Appearance="Primary"
                                   Margin="6,0,0,0"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Command="{Binding OpenGitHubIssuesCommand}"
                                   Content="{Binding OpenGitHubLabel}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                       Text="{Binding LicenseSectionTitle}"
                       Margin="0,0,0,12" />
            <Border Style="{StaticResource SettingsCardBorderStyle}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding LicenseText}" />
                    <ui:Button Appearance="Primary"
                               Margin="0,16,0,0"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Center"
                               Command="{Binding OpenGitHubRepositoryCommand}"
                               Content="{Binding OpenGitHubRepositoryLabel}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
