<Page x:Class="UI.Views.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      ScrollViewer.CanContentScroll="False">

    <Grid Margin="24"
          MaxWidth="900"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="72"
                    Height="72"
                    CornerRadius="18"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush Color="#FF1565C0" />
                </Border.Background>
                <ui:SymbolIcon Symbol="SwimmingPool24"
                               Foreground="White"
                               FontSize="40"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <TextBlock Style="{StaticResource TitleLargeTextBlockStyle}"
                           Text="{Binding ApplicationName}" />
                <TextBlock Margin="0,4,0,0"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           FontSize="{DynamicResource SwimDocFontSizeBody}"
                           Text="{Binding VersionText}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="{DynamicResource SwimDocFontSizeBody}"
                               Text="{Binding VersionSectionTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding UpdatesDescription}" />
                    <ui:Button Appearance="Primary"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Center"
                               Command="{Binding CheckForUpdatesCommand}"
                               Content="{Binding CheckForUpdatesLabel}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="{DynamicResource SwimDocFontSizeBody}"
                               Text="{Binding AuthorSectionTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="{DynamicResource SwimDocFontSizeBody}"
                               Text="{Binding AuthorName}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding AuthorLocation}" />
                    <TextBlock Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding CopyrightText}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource SettingsCardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                   FontSize="{DynamicResource SwimDocFontSizeBody}"
                                   Text="{Binding SupportSectionTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SupportDescription}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                MinWidth="280">
                        <ui:Button Appearance="Primary"
                                   Margin="0,0,0,8"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Command="{Binding OpenEmailCommand}"
                                   Content="{Binding OpenEmailLabel}" />
                        <ui:Button Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   Command="{Binding OpenGitHubIssuesCommand}"
                                   Content="{Binding OpenGitHubLabel}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
