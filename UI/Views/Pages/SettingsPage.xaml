<Page x:Class="UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      ScrollViewer.CanContentScroll="False">
    <TabControl Margin="12">
        <TabItem Header="Базовое время">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Button Content="{ui:SymbolIcon Save24}"
                            ToolTip="Сохранить"
                            Command="{Binding SaveCommand}"
                            HorizontalAlignment="Left"
                            Margin="5"
                            Padding="9" />

                    <GroupBox Header="SCM (25m) — Мужчины / Женщины" Margin="0,0,0,12">
                        <ui:DataGrid ItemsSource="{Binding ScmRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding WomenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding WomenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </ui:DataGrid>
                    </GroupBox>

                    <GroupBox Header="SCM (25m) — Смешанные эстафеты" Margin="0,0,0,12">
                        <ui:DataGrid ItemsSource="{Binding ScmMixedRelayRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MixedBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MixedSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*" />
                                <DataGridTemplateColumn Width="*" />
                            </DataGrid.Columns>
                        </ui:DataGrid>
                    </GroupBox>

                    <GroupBox Header="LCM (50m) — Мужчины / Женщины" Margin="0,0,0,12">
                        <ui:DataGrid ItemsSource="{Binding LcmRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding WomenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding WomenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </ui:DataGrid>
                    </GroupBox>

                    <GroupBox Header="LCM (50m) — Смешанные эстафеты">
                        <ui:DataGrid ItemsSource="{Binding LcmMixedRelayRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MixedBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox Style="{StaticResource SwimDocDataGridInlineTextBoxStyle}"
                                                Text="{Binding MixedSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*" />
                                <DataGridTemplateColumn Width="*" />
                            </DataGrid.Columns>
                        </ui:DataGrid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Page>