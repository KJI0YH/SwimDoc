<Page x:Class="UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:loc="clr-namespace:UI.Localization"
      xmlns:displayHelpers="clr-namespace:UI.Helpers.Display"
             xmlns:converters="clr-namespace:UI.Helpers.Converters"
             xmlns:uiHelpers="clr-namespace:UI.Helpers.Controls"
      xmlns:baseTimesView="clr-namespace:UI.Views.Controls.BaseTimesSettingsView"
      ScrollViewer.CanContentScroll="False">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <displayHelpers:AppLanguageDisplayConverter x:Key="AppLanguageDisplayConverter" />
    </Page.Resources>

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        
        <Grid x:Name="SettingsHubRoot"
              Margin="24,24,24,24"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              SizeChanged="SettingsHubRoot_OnSizeChanged">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBaseTimesOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <ScrollViewer x:Name="SettingsHubScroll"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="SettingsHubContent"
                        HorizontalAlignment="Stretch">
                <TextBlock Style="{StaticResource TitleLargeTextBlockStyle}"
                           Text="{loc:Localizastion Nav_Settings}"
                           Margin="0,0,0,8" />
                <TextBlock Margin="0,0,0,32"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="{loc:Localizastion Settings_Page_Subtitle}" />

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                           Text="{loc:Localizastion Settings_Section_General}"
                           Margin="0,0,0,12" />

                <Border Style="{StaticResource SettingsCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SettingsIconBadgeStyle}">
                            <ui:SymbolIcon Symbol="LocalLanguage24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Text="{loc:Localizastion Language_Label}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="{loc:Localizastion Settings_Language_Description}" />
                        </StackPanel>

                        <ComboBox Grid.Column="2"
                                  Width="200"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource AppLanguageDisplayConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Border>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                           Text="{loc:Localizastion Settings_Section_Paging}"
                           Margin="0,8,0,12" />

                <TextBlock Margin="0,0,0,12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="{loc:Localizastion Settings_Paging_Description}" />

                <ItemsControl ItemsSource="{Binding PagingSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SettingsCardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SettingsIconBadgeStyle}">
                                        <ui:SymbolIcon Symbol="{Binding IconSymbol}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="16,0,16,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}" />
                                    </StackPanel>

                                    <ui:NumberBox Grid.Column="2"
                                                  Style="{StaticResource SwimDocSettingsNumberBoxStyle}"
                                                  Value="{Binding PageSize, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                           Text="{loc:Localizastion Settings_Section_Files}"
                           Margin="0,8,0,12" />

                <Border Style="{StaticResource SettingsCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SettingsIconBadgeStyle}"
                                VerticalAlignment="Top">
                            <ui:SymbolIcon Symbol="DocumentArrowRight24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="16,0,16,0">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Text="{loc:Localizastion Templates_EntryDoc_Title}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="{loc:Localizastion Templates_EntryDoc_Subtitle}" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                VerticalAlignment="Center"
                                Padding="16,8"
                                Command="{Binding DownloadEntryDocumentTemplateCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowDownload24"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Localizastion Templates_Download}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                           Text="{loc:Localizastion Settings_Section_Competition}"
                           Margin="0,8,0,12" />

                <Button Style="{StaticResource SettingsNavCardButtonStyle}"
                        Command="{Binding OpenBaseTimesCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SettingsIconBadgeStyle}">
                            <ui:SymbolIcon Symbol="Timer24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Text="{loc:Localizastion Settings_Tab_BaseTime}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="{loc:Localizastion Settings_BaseTimes_Description}" />
                        </StackPanel>

                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="ChevronRight24"
                                       VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        
        <Grid Margin="24,24,24,24"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBaseTimesOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <baseTimesView:BaseTimesSettingsView DataContext="{Binding BaseTimes}"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Page>
