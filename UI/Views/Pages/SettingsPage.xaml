<Page x:Class="UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      ScrollViewer.CanContentScroll="False">
    <Page.Resources>
        <Style x:Key="SettingsDataGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>
    <TabControl Margin="12">
        <TabItem Header="Базовое время">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Button Content="{ui:SymbolIcon Save24}"
                            ToolTip="Сохранить"
                            Command="{Binding SaveCommand}"
                            HorizontalAlignment="Left"
                            Margin="5"
                            Padding="9" />

                    <GroupBox Header="SCM (25m) — Мужчины / Женщины" Margin="0,0,0,12">
                        <DataGrid ItemsSource="{Binding ScmRows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  ColumnHeaderStyle="{StaticResource SettingsDataGridColumnHeader}"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding WomenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding WomenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Header="SCM (25m) — Смешанные эстафеты" Margin="0,0,0,12">
                        <DataGrid ItemsSource="{Binding ScmMixedRelayRows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  ColumnHeaderStyle="{StaticResource SettingsDataGridColumnHeader}"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MixedBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MixedSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*" />
                                <DataGridTemplateColumn Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Header="LCM (50m) — Мужчины / Женщины" Margin="0,0,0,12">
                        <DataGrid ItemsSource="{Binding LcmRows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  ColumnHeaderStyle="{StaticResource SettingsDataGridColumnHeader}"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Мужчины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding WomenBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Женщины" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding WomenSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Header="LCM (50m) — Смешанные эстафеты">
                        <DataGrid ItemsSource="{Binding LcmMixedRelayRows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  ColumnHeaderStyle="{StaticResource SettingsDataGridColumnHeader}"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stroke" Binding="{Binding Name}" IsReadOnly="True"
                                                    Width="*" />
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MixedBaseTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.Header>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                            <TextBlock Text="Смешанные" HorizontalAlignment="Center"
                                                       TextAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Text="Базовое время, секунды" HorizontalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:TextBox
                                                Text="{Binding MixedSecondsText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*" />
                                <DataGridTemplateColumn Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Page>