<UserControl x:Class="UI.Views.Components.ImportInfoBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:media="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
             xmlns:helpers="clr-namespace:UI.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:IntGreaterThanZeroConverter x:Key="IntGt0" />
        <helpers:EnumDescriptionConverter x:Key="EnumDescription" />
        <helpers:RectHeightConverter x:Key="RectHeight" />
    </UserControl.Resources>

    <!-- Bottom overlay import status (does not shift content) -->
    <Border Padding="10"
            CornerRadius="10"
            Background="#F2FFFFFF"
            Visibility="{Binding IsImportBarOpen, Converter={StaticResource BoolToVis}}">
        <Border.Effect>
            <media:DropShadowEffect BlurRadius="14" Opacity="0.25" ShadowDepth="2" />
        </Border.Effect>

        <StackPanel>
            <!-- Compact bar -->
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button ToolTip="Подробнее"
                            Margin="5,0,0,0"
                            Padding="9"
                            Command="{Binding ToggleImportDetailsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="{ui:SymbolIcon ChevronDown24}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportDetailsOpen}" Value="True">
                                        <Setter Property="Content" Value="{ui:SymbolIcon ChevronUp24}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{ui:SymbolIcon Stop24}"
                            ToolTip="Прервать"
                            Margin="5,0,0,0"
                            Padding="9"
                            Command="{Binding CancelImportCommand}"
                            Visibility="{Binding IsImportRunning, Converter={StaticResource BoolToVis}}" />

                    <Button ToolTip="Закрыть"
                            Margin="5,0,0,0"
                            Padding="9"
                            Command="{Binding DismissImportBarCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="{ui:SymbolIcon Dismiss24}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportRunning}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="{Binding ImportHeader}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ImportMessage}" Opacity="0.8" />
                    <ProgressBar Height="6"
                                 Margin="0,8,0,0"
                                 IsIndeterminate="{Binding IsImportRunning}"
                                 Minimum="0"
                                 Maximum="{Binding ImportTotalFiles}"
                                 Value="{Binding ImportProcessedFiles}" />
                </StackPanel>
            </DockPanel>

            <Border Margin="0,10,0,0"
                    Visibility="{Binding IsImportDetailsOpen, Converter={StaticResource BoolToVis}}"
                    MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Converter={StaticResource RectHeight}, ConverterParameter=0.55}"
                    ClipToBounds="True">
                <StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <DataGrid ItemsSource="{Binding ImportFiles}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  RowDetailsVisibilityMode="VisibleWhenSelected"
                                  x:Name="FilesGrid">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridRow_PreviewMouseLeftButtonDown" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#140EA5E9" />
                                        <Setter Property="BorderBrush" Value="#660EA5E9" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10">
                                    <GroupBox Margin="0,0,0,8">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <ContentControl Content="{ui:SymbolIcon Warning24}"
                                                                Foreground="#D97706"
                                                                Margin="0,0,6,0" />
                                                <TextBlock Foreground="#D97706"
                                                           Text="{Binding WarningsCount, StringFormat=Предупреждения ({0})}" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Warnings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </GroupBox>

                                    <GroupBox>
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <ContentControl Content="{ui:SymbolIcon ErrorCircle24}"
                                                                Foreground="#B91C1C"
                                                                Margin="0,0,6,0" />
                                                <TextBlock Foreground="#B91C1C"
                                                           Text="{Binding ErrorsCount, StringFormat=Ошибки ({0})}" />
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Errors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </GroupBox>
                                </StackPanel>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Файл" Binding="{Binding FileName}" Width="150" />
                            <DataGridTextColumn Header="Путь" Binding="{Binding FullPath}" Width="*" />
                            <DataGridTextColumn Header="Статус" Width="180"
                                                Binding="{Binding Status, Converter={StaticResource EnumDescription}}" />
                            <DataGridTemplateColumn Header="Команды" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding ClubsAdded}" />
                                            <Run Text="/" />
                                            <Run Text="{Binding ClubsUpdated}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Спортсмены" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding AthletesAdded}" />
                                            <Run Text="/" />
                                            <Run Text="{Binding AthletesUpdated}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Заявки" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding EntriesAdded}" />
                                            <Run Text="/" />
                                            <Run Text="{Binding EntriesUpdated}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Предупреждения" Binding="{Binding WarningsCount}" Width="170" />
                            <DataGridTextColumn Header="Ошибки" Binding="{Binding ErrorsCount}" Width="100" />
                        </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>