<Window x:Class="UI.Views.Windows.ReportGeneration.ReportGenerationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        xmlns:loc="clr-namespace:UI.Localization"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <addEditView:AddEditWindowView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <CheckBox Content="{loc:Loc Reports_Include_EntryList}"
                          IsChecked="{Binding IncludeEntryList, Mode=TwoWay}" />
                <CheckBox Content="{loc:Loc Reports_Include_StartList}"
                          IsChecked="{Binding IncludeStartList, Mode=TwoWay}"
                          Margin="0,5,0,0" />
                <CheckBox Content="{loc:Loc Reports_Include_FinishList}"
                          IsChecked="{Binding IncludeFinishList, Mode=TwoWay}"
                          Margin="0,5,0,0" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="{loc:Loc Reports_Field_OutputFile}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding OutputFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="320"
                         Margin="0,0,10,0" />
                <ui:Button Grid.Column="1"
                           Content="{ui:SymbolIcon Folder24}"
                           Padding="9"
                           Command="{Binding BrowseCommand}" />
            </Grid>
        </Grid>
    </addEditView:AddEditWindowView>
</Window>

