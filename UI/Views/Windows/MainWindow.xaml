<ui:FluentWindow x:Class="UI.Views.Windows.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:UI.ViewModels"
                 xmlns:views="clr-namespace:UI.Views"
                 xmlns:pages="clr-namespace:UI.Views.Pages"
                 xmlns:vm1="clr-namespace:UI.ViewModels.Pages"
                 xmlns:competitionSelectionView="clr-namespace:UI.Views.Controls.CompetitionSelectionView"
                 xmlns:dataGridView="clr-namespace:UI.Views.Controls.DataGridView"
                 mc:Ignorable="d"
                 Title="SwimDoc"
                 WindowState="Maximized"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True">
    <Window.InputBindings>
        <KeyBinding Key="N"
                    Modifiers="Control"
                    Command="{Binding CompetitionSelectionViewModel.CreateNewCommand}" />
        <KeyBinding Key="O"
                    Modifiers="Control"
                    Command="{Binding CompetitionSelectionViewModel.OpenExistingCommand}" />
    </Window.InputBindings>
    <ui:FluentWindow.Resources>
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="47" />
            <Setter Property="Height" Value="47" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RestoreWindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseWindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ui:NavigationViewItem">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate DataType="{x:Type vm1:CompetitionSelectionViewModel}">
            <competitionSelectionView:CompetitionSelectionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:EventsViewModel}">
            <dataGridView:EventsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:HeatsViewModel}">
            <dataGridView:HeatsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:EntriesViewModel}">
            <dataGridView:EntriesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:AthletesViewModel}">
            <dataGridView:AthletesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:ClubsViewModel}">
            <dataGridView:ClubsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:AgeGroupsViewModel}">
            <dataGridView:AgeGroupsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm1:SwimStylesViewModel}">
            <dataGridView:SwimStylesView />
        </DataTemplate>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Menu VerticalAlignment="Center">
                <MenuItem Header="Соревнование">
                    <MenuItem Header="Создать"
                              InputGestureText="Ctrl+N"
                              Command="{Binding CompetitionSelectionViewModel.CreateNewCommand}" />
                    <MenuItem Header="Открыть"
                              InputGestureText="Ctrl+O"
                              Command="{Binding CompetitionSelectionViewModel.OpenExistingCommand}" />
                </MenuItem>
            </Menu>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource RestoreWindowControlButtonStyle}"
                        Click="MinimizeButton_Click"
                        ToolTip="Minimize"
                        Content="{ui:SymbolIcon Subtract24}" />
                <Button x:Name="RestoreButton"
                        Style="{StaticResource RestoreWindowControlButtonStyle}"
                        Click="RestoreButton_Click"
                        ToolTip="Restore"
                        Content="{ui:SymbolIcon SquareMultiple24}" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseWindowControlButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTip="Close"
                        Content="{ui:SymbolIcon Dismiss24}" />
            </StackPanel>
        </Grid>

        <ui:NavigationView Grid.Row="1" x:Name="NavigationView"
                           PaneDisplayMode="Left"
                           OpenPaneLength="200"
                           IsBackButtonVisible="Auto"
                           Loaded="NavigationView_OnLoaded">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Программа"
                                       Tag="Events"
                                       Icon="{ui:SymbolIcon CalendarLtr24}"
                                       TargetPageType="{x:Type pages:EventsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Заявки"
                                       Tag="Entries"
                                       Icon="{ui:SymbolIcon DocumentCopy24}"
                                       TargetPageType="{x:Type pages:EntriesPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Заплывы"
                                       Tag="Heats"
                                       Icon="{ui:SymbolIcon SwimmingPool24}"
                                       TargetPageType="{x:Type pages:HeatsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Фиксация"
                                       Tag="HeatsResults"
                                       Icon="{ui:SymbolIcon Clock24}"
                                       TargetPageType="{x:Type pages:FixationPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Результаты"
                                       Tag="Results"
                                       Icon="{ui:SymbolIcon Trophy24}"
                                       TargetPageType="{x:Type pages:ResultsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItemSeparator />
                <ui:NavigationViewItem Content="Спортсмены"
                                       Tag="Athletes"
                                       Icon="{ui:SymbolIcon People24}"
                                       TargetPageType="{x:Type pages:AthletesPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Команды"
                                       Tag="Clubs"
                                       Icon="{ui:SymbolIcon BuildingTownhouse24}"
                                       TargetPageType="{x:Type pages:ClubsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItemSeparator />
                <ui:NavigationViewItem Content="Возрастные группы"
                                       Tag="AgeGroups"
                                       Icon="{ui:SymbolIcon GroupList24}"
                                       TargetPageType="{x:Type pages:AgeGroupsPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
                <ui:NavigationViewItem Content="Дистанции"
                                       Tag="SwimStyles"
                                       Icon="{ui:SymbolIcon Accessibility24}"
                                       TargetPageType="{x:Type pages:SwimStylesPage}"
                                       IsEnabled="{Binding IsCompetitionSelected}" />
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="Настройки"
                    Tag="Settings"
                    Icon="{ui:SymbolIcon Settings24}"
                    TargetPageType="{x:Type pages:SettingsPage}" />
                <ui:NavigationViewItem
                    Content="О программе"
                    Tag="Settings"
                    Icon="{ui:SymbolIcon Info24}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
        <Border x:Name="ModalOverlay"
                Grid.RowSpan="2"
                Panel.ZIndex="1000"
                Background="#80000000"
                Visibility="Collapsed"
                IsHitTestVisible="False" />
        <ui:ContentDialogHost x:Name="RootContentDialog"
                              Grid.RowSpan="2"
                              Panel.ZIndex="1001" />
    </Grid>
</ui:FluentWindow>