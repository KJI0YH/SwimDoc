<Window x:Class="UI.Views.Windows.AddEdit.EventAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UI.Helpers"
        xmlns:controls="clr-namespace:UI.Views.Controls"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        xmlns:searchableComboBox="clr-namespace:UI.Views.Controls.SearchableComboBox"
        xmlns:loc="clr-namespace:UI.Localization"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <helpers:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
        <helpers:NullableIntConverter x:Key="NullableIntConverter" />
    </Window.Resources>
    <addEditView:AddEditWindowView>
        <StackPanel>
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_Order}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />

                <ui:NumberBox Grid.Column="1"
                              Value="{Binding Order, UpdateSourceTrigger=PropertyChanged}"
                              Margin="2,2,0,2" />

            </Grid>
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_Date}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding SelectedDate, UpdateSourceTrigger=PropertyChanged}"
                            SelectedDateFormat="Short"
                            Language="ru-RU"
                            Margin="0,2,0,2" />
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_Time}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <UniformGrid Grid.Column="1" Columns="2">
                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding HourOptions}"
                              Text="{Binding HourText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,2,2,2" />
                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding MinuteOptions}"
                              Text="{Binding MinuteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="2,2,0,2" />
                </UniformGrid>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_SwimStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <searchableComboBox:SearchableComboBox Grid.Column="1"
                                                       ItemsSource="{Binding SwimStyles}"
                                                       SelectedItem="{Binding SelectedSwimStyle, Mode=TwoWay}"
                                                       Margin="0,2,0,2" />
                <Button Grid.Column="2"
                        Content="{ui:SymbolIcon Add24}"
                        Command="{Binding CreateNewSwimStyleCommand}"
                        Margin="5,2,0,2"
                        Padding="9" />
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_AgeGroup}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <searchableComboBox:SearchableComboBox Grid.Column="1"
                                                       ItemsSource="{Binding AgeGroups}"
                                                       SelectedItem="{Binding SelectedAgeGroup, Mode=TwoWay}"
                                                       Margin="0,2,0,2" />
                <Button Grid.Column="2"
                        Content="{ui:SymbolIcon Add24}"
                        Command="{Binding CreateNewAgeGroupCommand}"
                        Margin="5,2,0,2"
                        Padding="9" />
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_Course}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding CourseValues}"
                          SelectedItem="{Binding Course, Mode=TwoWay}"
                          Margin="0,2,0,2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_Round}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding EventRoundValues}"
                          SelectedItem="{Binding Round}"
                          Margin="0,2,0,2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_PreviousEvent}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <searchableComboBox:SearchableComboBox Grid.Column="1"
                                                       ItemsSource="{Binding PreviousSwimEvents}"
                                                       SelectedItem="{Binding SelectedPreviousSwimEvent, Mode=TwoWay}"
                                                       Margin="0,2,0,2" />
                <Button Grid.Column="2"
                        Content="{ui:SymbolIcon Add24}"
                        Command="{Binding CreateNewSwimEventCommand}"
                        Margin="5,2,0,2"
                        Padding="9" />
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_RoundParticipantsCount}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:NumberBox Grid.Column="1"
                              PlaceholderText="{loc:Loc Common_All}"
                              Value="{Binding RoundParticipantsCount, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}, TargetNullValue=''}"
                              Margin="0,2,0,2" />
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Event_Field_AvailableLanes}"
                           VerticalAlignment="Top"
                           Margin="0,4,10,0" />
                <TabControl Grid.Column="1"
                            SelectedIndex="{Binding LaneTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,2,0,2">
                    <TabItem Header="{loc:Loc Event_Lanes_Tab_Range}">
                        <UniformGrid Columns="2" Margin="4">
                            <ui:NumberBox Minimum="0"
                                          PlaceholderText="{loc:Loc Common_Min}"
                                          Value="{Binding LaneMin, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,2,0" />
                            <ui:NumberBox Minimum="{Binding LaneMin, UpdateSourceTrigger=PropertyChanged}"
                                          PlaceholderText="{loc:Loc Common_Max}"
                                          Value="{Binding LaneMax, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2,0,0,0" />
                        </UniformGrid>
                    </TabItem>
                    <TabItem Header="{loc:Loc Event_Lanes_Tab_Custom}">
                        <ui:TextBox PlaceholderText="{loc:Loc Event_Field_CustomLaneNames_Placeholder}"
                                    Text="{Binding CustomLaneNames, UpdateSourceTrigger=PropertyChanged}"
                                    AcceptsReturn="False"
                                    Margin="4" />
                    </TabItem>
                </TabControl>
            </Grid>
        </StackPanel>
    </addEditView:AddEditWindowView>
</Window>