<Window x:Class="UI.Views.Windows.AddEdit.HeatAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UI.Helpers"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        xmlns:searchableComboBox="clr-namespace:UI.Views.Controls.SearchableComboBox"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <helpers:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </Window.Resources>

    <addEditView:AddEditWindowView Width="520">
        <StackPanel Margin="0,0,0,15">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Номер заплыва"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:NumberBox Grid.Column="1"
                              Value="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                              Minimum="{Binding MinHeatNumber}"
                              IsEnabled="{Binding CanEditFields}"
                              Margin="0,2,0,2" />
            </Grid>
            
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Время старта"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <UniformGrid Grid.Column="1" Columns="2">

                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding HourOptions}"
                              Text="{Binding HourText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding CanEditFields}"
                              Margin="0,2,2,2" />

                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding MinuteOptions}"
                              Text="{Binding MinuteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding CanEditFields}"
                              Margin="2,2,0,2" />
                </UniformGrid>
            </Grid>
            
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Статус"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding HeatStatusValues}"
                          SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding CanEditFields}"
                          Margin="0,2,0,2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <DockPanel Margin="0,10,0,5">
                <Button DockPanel.Dock="Right"
                        Content="{ui:SymbolIcon Add24}"
                        Command="{Binding AddPositionRowCommand}"
                        ToolTip="Добавить"
                        Padding="9"
                        Margin="5,0,0,0" />
            </DockPanel>

            <DataGrid ItemsSource="{Binding PositionRows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      Height="515"
                      Margin="0,0,0,5">
                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Дорожка" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:NumberBox Value="{Binding Lane, UpdateSourceTrigger=PropertyChanged}"
                                              Minimum="{Binding DataContext.LaneMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Maximum="{Binding DataContext.LaneMax, RelativeSource={RelativeSource AncestorType=Window}}"
                                              IsEnabled="{Binding DataContext.CanEditFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Margin="2" />
                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Заявка" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <searchableComboBox:SearchableComboBox
                                    ItemsSource="{Binding AvailableEntries}"
                                    SelectedItem="{Binding SelectedEntry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding DataContext.CanEditFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="" Width="48">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{ui:SymbolIcon Delete24}"
                                        Command="{Binding RemoveCommand}"
                                        CommandParameter="{Binding}"
                                        Padding="9"
                                        Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </addEditView:AddEditWindowView>
</Window>