<Window x:Class="UI.Views.Windows.AddEdit.GenericAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <addEditView:AddEditWindowView>
        <ItemsControl ItemsSource="{Binding PropertyEditors}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Label}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <ContentControl Grid.Column="1"
                                        Content="{Binding Editor}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </addEditView:AddEditWindowView>
</Window>