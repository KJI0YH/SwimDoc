<Window x:Class="UI.Views.Windows.AddEdit.AgeGroupAddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UI.Helpers"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <helpers:NullableIntConverter x:Key="NullableIntConverter" />
        <helpers:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </Window.Resources>
    <addEditView:AddEditWindowView>
        <StackPanel Margin="0,0,0,15">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Название"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:TextBox Grid.Column="1"
                            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Auto"
                            Margin="0,2,0,2" />
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Пол"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding GenderValues}"
                          SelectedItem="{Binding Gender}"
                          Margin="0,2,0,2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Год рождения"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <UniformGrid Grid.Column="1" Columns="2">
                    <ui:NumberBox PlaceholderText="Absolute (min)"
                                  Value="{Binding BirthYearMin, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}, TargetNullValue=''}"
                                  Margin="0,2,2,2"
                                  Minimum="1900" />
                    <ui:NumberBox PlaceholderText="Absolute (max)"
                                  Value="{Binding BirthYearMax, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntConverter}, TargetNullValue=''}"
                                  Margin="2, 2, 0, 2"
                                  Minimum="1900" />
                </UniformGrid>
            </Grid>
        </StackPanel>
    </addEditView:AddEditWindowView>
</Window>