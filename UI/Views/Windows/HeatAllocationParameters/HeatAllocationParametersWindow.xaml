<Window x:Class="UI.Views.Windows.HeatAllocationParameters.HeatAllocationParametersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:heatLogic="clr-namespace:BizLogic.HeatLogic;assembly=BizLogic"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <addEditView:AddEditWindowView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Порядок заплывов"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ComboBox Grid.Column="1"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding SelectedHeatOrder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBoxItem Content="От слабого к сильному"
                                  Tag="{x:Static heatLogic:HeatOrder.FromWeakToStrong}" />
                    <ComboBoxItem Content="От сильного к слабому"
                                  Tag="{x:Static heatLogic:HeatOrder.FromStrongToWeak}" />
                </ComboBox>
            </Grid>

            <Grid Grid.Row="1" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Минимум в заплыве"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:NumberBox Grid.Column="1"
                              Minimum="1"
                              Value="{Binding MinHeatSize, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Grid>
    </addEditView:AddEditWindowView>
</Window>