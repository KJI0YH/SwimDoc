<Window x:Class="UI.Views.Windows.StartTimeCalculation.StartTimeCalculationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:addEditView="clr-namespace:UI.Views.Controls.AddEditView"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <addEditView:AddEditWindowView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Время начала"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <UniformGrid Grid.Column="1" Columns="2">
                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding HourOptions}"
                              Text="{Binding HourText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,2,2,2" />
                    <ComboBox IsEditable="True"
                              ItemsSource="{Binding MinuteOptions}"
                              Text="{Binding MinuteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="2,2,0,2" />
                </UniformGrid>
            </Grid>

            <Grid Grid.Row="1" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Пауза между заплывами (минут)"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:NumberBox Grid.Column="1"
                              Minimum="0"
                              Value="{Binding HeatPauseMinutes, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,2,0,2" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Пауза между событиями (минут)"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <ui:NumberBox Grid.Column="1"
                              Minimum="0"
                              Value="{Binding EventPauseMinutes, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,2,0,2" />
            </Grid>
        </Grid>
    </addEditView:AddEditWindowView>
</Window>
