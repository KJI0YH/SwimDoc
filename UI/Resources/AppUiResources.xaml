<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:displayHelpers="clr-namespace:UI.Helpers.Display"
             xmlns:converters="clr-namespace:UI.Helpers.Converters"
                    xmlns:uiHelpers="clr-namespace:UI.Helpers.Controls"
                    xmlns:searchableComboBox="clr-namespace:UI.Views.Controls.SearchableComboBox"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <converters:EntryScoringConverter x:Key="EntryScoringConverter" />
    <displayHelpers:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />

    <DataTemplate x:Key="EnumComboBoxItemTemplate">
        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
    </DataTemplate>

    <Style x:Key="EnumComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="ItemTemplate" Value="{StaticResource EnumComboBoxItemTemplate}" />
    </Style>

    
    <system:Double x:Key="SwimDocFilterDateWidth">120</system:Double>
    <system:Double x:Key="SwimDocFilterRoundWidth">108</system:Double>
    <system:Double x:Key="SwimDocFilterDistanceWidth">168</system:Double>
    <system:Double x:Key="SwimDocFilterStrokeWidth">168</system:Double>
    <system:Double x:Key="SwimDocFilterGenderWidth">120</system:Double>
    <system:Double x:Key="SwimDocFilterStatusWidth">172</system:Double>
    <system:Double x:Key="SwimDocSwimEventComboBoxWidth">500</system:Double>
    <system:Double x:Key="SwimDocHeatNumberComboBoxWidth">96</system:Double>
    <system:Double x:Key="SwimDocAgeGroupComboBoxWidth">500</system:Double>

    <Style x:Key="SwimDocSwimEventComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="uiHelpers:ComboBoxFixedWidthHelper.Width" Value="{StaticResource SwimDocSwimEventComboBoxWidth}" />
    </Style>

    <Style x:Key="SwimDocSwimEventSearchableComboBoxStyle"
           TargetType="searchableComboBox:SearchableComboBox">
        <Setter Property="uiHelpers:ComboBoxFixedWidthHelper.Width" Value="{StaticResource SwimDocSwimEventComboBoxWidth}" />
    </Style>

    <Style x:Key="SwimDocHeatNumberComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="uiHelpers:ComboBoxFixedWidthHelper.Width" Value="{StaticResource SwimDocHeatNumberComboBoxWidth}" />
    </Style>

    <Style x:Key="SwimDocAgeGroupComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="uiHelpers:ComboBoxFixedWidthHelper.Width" Value="{StaticResource SwimDocAgeGroupComboBoxWidth}" />
    </Style>

    
    <system:Double x:Key="SwimDocFontSizeCaption">16</system:Double>
    <system:Double x:Key="SwimDocFontSizeBody">16</system:Double>
    <system:Double x:Key="SwimDocFontSizeSubtitle">16</system:Double>
    <system:Double x:Key="SwimDocFontSizeTitle">16</system:Double>
    <system:Double x:Key="SwimDocFontSizeDisplay">16</system:Double>

    
    <system:Double x:Key="ControlContentThemeFontSize">16</system:Double>
    <system:Double x:Key="ContentControlFontSize">16</system:Double>

    <Style TargetType="Window">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="{x:Type ui:FluentWindow}"
           BasedOn="{StaticResource {x:Type ui:FluentWindow}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="Page">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style x:Key="SwimDocAccentProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    </Style>

    <Style x:Key="CaptionTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeCaption}" />
    </Style>

    <Style x:Key="BodyTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style x:Key="BodyStrongTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubtitleTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeSubtitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="TitleTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="TitleLargeTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DisplayTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="TextBox"
           BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Style.Triggers>
            <Trigger Property="IsEditable" Value="True">
                <Setter Property="uiHelpers:EditableComboBoxBehavior.IsEnabled" Value="True" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Label"
           BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="Menu"
           BasedOn="{StaticResource {x:Type Menu}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="MenuItem"
           BasedOn="{StaticResource {x:Type MenuItem}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="GroupBox"
           BasedOn="{StaticResource {x:Type GroupBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="TabControl"
           BasedOn="{StaticResource {x:Type TabControl}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="TabItem"
           BasedOn="{StaticResource {x:Type TabItem}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="CheckBox"
           BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <Style TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
    </Style>

    <SolidColorBrush x:Key="DataGridSelectedRowBackgroundBrush" Color="#FFE3F2FD" />
    <SolidColorBrush x:Key="DataGridRowHoverBackgroundBrush" Color="#FFE8EEF7" />
    <SolidColorBrush x:Key="ResultPlaceGoldBrush" Color="#FFFFF0B2" />
    <SolidColorBrush x:Key="ResultPlaceSilverBrush" Color="#FFE8E8E8" />
    <SolidColorBrush x:Key="ResultPlaceBronzeBrush" Color="#FFFFE4C4" />
    <SolidColorBrush x:Key="SwimDocDataGridHorizontalLineBrush" Color="#FFE0E0E0" />

    
    <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#14000000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="DialogFormRowStyle" TargetType="Grid">
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style x:Key="DialogChromeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="SettingsCardBorderStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource DataGridSelectedRowBackgroundBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SettingsNavCardButtonStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            <Setter TargetName="border" Property="BorderBrush"
                                    Value="{DynamicResource AccentFillColorDefaultBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SwimDocSettingsNumberBoxStyle"
           TargetType="ui:NumberBox"
           BasedOn="{StaticResource {x:Type ui:NumberBox}}">
        <Setter Property="Width" Value="132" />
        <Setter Property="Minimum" Value="1" />
        <Setter Property="Maximum" Value="500" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="SpinButtonPlacementMode" Value="Inline" />
        <Setter Property="ClearButtonEnabled" Value="False" />
    </Style>

    
    <Style x:Key="SwimDocDataGridTextColumnElementStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    
    <Style x:Key="SwimDocDataGridTextColumnEditingElementStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    
    <Style x:Key="SwimDocDataGridInlineTextBoxStyle"
           TargetType="ui:TextBox"
           BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="SwimDocDataGridInlineComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <DataTemplate x:Key="EventFilterOptionTemplate">
        <Border Margin="{DynamicResource ComboBoxItemMargin}"
                Padding="{DynamicResource ComboBoxItemContentMargin}"
                CornerRadius="{DynamicResource ControlCornerRadius}"
                Cursor="Hand"
                SnapsToDevicePixels="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="{StaticResource DataGridSelectedRowBackgroundBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Rectangle Width="3"
                           Height="16"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           RadiusX="2"
                           RadiusY="2"
                           Fill="{DynamicResource SystemAccentColorPrimaryBrush}"
                           Visibility="Collapsed">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <TextBlock Margin="8,0,0,0"
                           Text="{Binding DisplayText}"
                           FontSize="{DynamicResource SwimDocFontSizeBody}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </DataTemplate>

    <Style TargetType="DataGridColumnHeader"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
            </Trigger>
            <Trigger Property="SortDirection" Value="Ascending">
                <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            </Trigger>
            <Trigger Property="SortDirection" Value="Descending">
                <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell"
           BasedOn="{StaticResource {x:Type DataGridCell}}">
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                         Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
            </DataTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow"
           BasedOn="{StaticResource {x:Type DataGridRow}}">
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Margin" Value="0" />
        <Style.Triggers>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource DataGridRowHoverBackgroundBrush}" />
            </MultiTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource DataGridSelectedRowBackgroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGrid"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource SwimDocDataGridHorizontalLineBrush}" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="uiHelpers:DataGridHorizontalScrollHelper.IsEnabled" Value="True" />
    </Style>

    <Style TargetType="{x:Type ui:DataGrid}"
           BasedOn="{StaticResource {x:Type ui:DataGrid}}">
        <Setter Property="FontSize" Value="{DynamicResource SwimDocFontSizeBody}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource SwimDocDataGridHorizontalLineBrush}" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="uiHelpers:DataGridHorizontalScrollHelper.IsEnabled" Value="True" />
        <Setter Property="TextColumnElementStyle" Value="{StaticResource SwimDocDataGridTextColumnElementStyle}" />
        <Setter Property="TextColumnEditingElementStyle" Value="{StaticResource SwimDocDataGridTextColumnEditingElementStyle}" />
    </Style>

    
    <Style x:Key="DataGridRowLightBlueWhenSelectedStyle"
           TargetType="DataGridRow"
           BasedOn="{StaticResource {x:Type DataGridRow}}">
        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Converter={StaticResource EntryScoringConverter}}"
                               Value="False" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="LightGray" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Converter={StaticResource EntryScoringConverter}}"
                               Value="False" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                               Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#FFC8C8C8" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Converter={StaticResource EntryScoringConverter}}"
                               Value="True" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                               Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource DataGridRowHoverBackgroundBrush}" />
            </MultiDataTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource DataGridSelectedRowBackgroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    
    <Style x:Key="DataGridRowResultsPlaceStyle"
           TargetType="DataGridRow"
           BasedOn="{StaticResource DataGridRowLightBlueWhenSelectedStyle}">
        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RankingPlace}" Value="1" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource ResultPlaceGoldBrush}" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RankingPlace}" Value="2" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource ResultPlaceSilverBrush}" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RankingPlace}" Value="3" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource ResultPlaceBronzeBrush}" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RankingPlace}" Value="1" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                               Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#FFFFE699" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RankingPlace}" Value="2" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                               Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#FFD0D0D0" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RankingPlace}" Value="3" />
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                               Value="False" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}"
                               Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#FFFFD4A3" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
